{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutBFraction"},"variants":[{"paths":["\/documentation\/bigint\/aboutbfraction"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutBInt","doc:\/\/bigint.BigInt\/documentation\/BigInt\/AboutCRT","doc:\/\/bigint.BigInt\/documentation\/BigInt\/Performance","doc:\/\/bigint.BigInt\/documentation\/BigInt\/References","doc:\/\/bigint.BigInt\/documentation\/BigInt\/Algorithms","doc:\/\/bigint.BigInt\/documentation\/BigInt\/Protocols"],"title":"Articles","generated":true,"anchor":"Articles"}],"hierarchy":{"paths":[["doc:\/\/bigint.BigInt\/documentation\/BigInt"]]},"abstract":[{"text":"Signed fractions with numerator and denominator of unbounded size","type":"text"}],"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"modules":[{"name":"BigInt"}],"title":"About BFraction","roleHeading":"Article","role":"article"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Fractions are represented as ","type":"text"},{"type":"reference","identifier":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/BFraction","isActive":true},{"type":"text","text":" values consisting of a "},{"identifier":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/BInt","type":"reference","isActive":true},{"type":"text","text":" numerator value and a "},{"type":"reference","identifier":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/BInt","isActive":true},{"text":" denominator value. The representation is normalized:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"The numerator and denominator have no common factors except 1","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The denominator is always positive"}]}]},{"content":[{"inlineContent":[{"text":"Zero is represented as 0\/1","type":"text"}],"type":"paragraph"}]}]},{"type":"heading","level":3,"anchor":"Creating-BFractions","text":"Creating BFraction’s"},{"code":["\/\/ From its numerator and denominator","let f = BFraction(17, 4)","","\/\/ From its decimal value","let f = BFraction(4.25)","","\/\/ From its string representation","let f = BFraction(\"4.25\")!","\/\/ or equivalently","let f = BFraction(\"425E-2\")!","","\/\/ From a continued fraction","let f = BFraction([3, 4, 12, 4])  \/\/ f = 649 \/ 200"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Defining a fraction by specifying its decimal value might lead to surprises,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"because not all decimal values can be represented exactly as a floating point number."}]},{"type":"paragraph","inlineContent":[{"text":"One might think that ","type":"text"},{"type":"codeVoice","code":"BFraction(0.1)"},{"type":"text","text":" would equal 1\/10,"},{"type":"text","text":" "},{"text":"but in fact it equals 3602879701896397 \/ 36028797018963968 = 0.1000000000000000055511151231257827021181583404541015625","type":"text"}]},{"inlineContent":[{"type":"text","text":"On the other hand "},{"type":"codeVoice","code":"BFraction(\"0.1\")!"},{"type":"text","text":" equals 1\/10."}],"type":"paragraph"},{"type":"heading","text":"Converting BFraction’s","level":3,"anchor":"Converting-BFractions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"BFraction values can be converted to String values, to decimal String values, to Double values and to Continued Fraction values."}]},{"type":"codeListing","code":["let x = BFraction(1000, 7)","","\/\/ To String","let s1 = x.asString() \/\/ s1 = \"1000 \/ 7\"","","\/\/ To decimal String","let s1 = x.asDecimalString(precision: 8, exponential: false) \/\/ s1 = \"142.85714\"","let s2 = x.asDecimalString(precision: 8, exponential: true) \/\/ s2 = \"1.4285714E+2\"","","\/\/ To Double","let d = x.asDouble() \/\/ d = 142.8571428571429","","\/\/ To Continued Fraction","let f = x.asContinuedFraction() \/\/ f = [BInt(142), BInt(1), BInt(6)]"],"syntax":"swift"},{"text":"Operations","level":3,"anchor":"Operations","type":"heading"},{"inlineContent":[{"type":"text","text":"The operations available to "},{"code":"BFraction","type":"codeVoice"},{"type":"text","text":" are:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Arithmetic:"}]},{"type":"text","text":" addition, subtraction, multiplication, division, exponentiation, modulus"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Comparison:","type":"text"}]},{"text":" The six standard operations ==  !=  <  <=  >  >=","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Rounding:"}]},{"text":" Rounding fractions to integers","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Miscellaneous:"}],"type":"strong"},{"type":"text","text":" Bernoulli Numbers, Harmonic Numbers"}]}]}]},{"level":3,"type":"heading","anchor":"Bernoulli-Numbers","text":"Bernoulli Numbers"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The static function"}]},{"type":"codeListing","syntax":"swift","code":["let Bn = BFraction.bernoulli(n)"]},{"inlineContent":[{"text":"computes the n’th (n >= 0) Bernoulli number, which is a rational number.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For example","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["print(BFraction.bernoulli(60))","print(BFraction.bernoulli(60).asDecimalString(precision: 20, exponential: true))"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"would print"}]},{"type":"codeListing","code":["-1215233140483755572040304994079820246041491 \/ 56786730","-2.1399949257225333665E+34"],"syntax":"swift"},{"inlineContent":[{"text":"The static function","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["let x = BFraction.bernoulliSequence(n)"],"syntax":"swift"},{"inlineContent":[{"text":"computes the n even numbered Bernoulli numbers B(0), B(2) … B(2 * n - 2).","type":"text"}],"type":"paragraph"},{"anchor":"Harmonic-Numbers","text":"Harmonic Numbers","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"The static function"}],"type":"paragraph"},{"syntax":"swift","code":["let Hn = BFraction.harmonic(n)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"computes the n’th harmonic number, that is, 1 + 1\/2 + … + 1\/n"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The static function"}]},{"code":["let x = BFraction.harmonicSequence(n)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"returns an array containing the first n harmonic numbers."}],"type":"paragraph"}]}],"references":{"doc://bigint.BigInt/documentation/BigInt/Protocols":{"url":"\/documentation\/bigint\/protocols","role":"article","title":"Protocols and Additions","type":"topic","abstract":[{"text":"BigInt supports the standard integer data type’s SignedInteger, BinaryInteger, Codable, and Numeric protocols.","type":"text"}],"kind":"article","identifier":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/Protocols"},"doc://bigint.BigInt/documentation/BigInt/BFraction":{"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"BFraction","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"BFraction","kind":"identifier"}],"abstract":[{"text":"The BFraction structure","type":"text"}],"url":"\/documentation\/bigint\/bfraction","type":"topic","identifier":"doc:\/\/bigint.BigInt\/documentation\/BigInt\/BFraction",